rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    match /users/{userId} {
      function isValidUser(data) {
        return data.size() == 2
               && data.keys().hasAll(['displayName', 'createdAt'])
               && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100
               && data.createdAt is timestamp;
      }
      
      allow read: if true;
      
      allow create: if isSignedIn() 
                    && request.auth.uid == userId 
                    && isValidUser(incoming())
                    && incoming().createdAt == request.time;
                    
      allow update: if isSignedIn() 
                    && request.auth.uid == userId 
                    && isValidUser(incoming())
                    && incoming().createdAt == existing().createdAt;
      
      allow delete: if false;
    }
    
    match /reviews/{reviewId} {
      function isValidReview(data) {
        return data.keys().hasAll(['userId', 'userName', 'entityId', 'entityTitle', 'rating', 'comment', 'createdAt'])
               && data.size() == 7
               && data.userId is string && data.userId == request.auth.uid
               && data.userName is string && data.userName.size() <= 100
               && data.entityId is string && data.entityId.size() <= 128
               && data.entityTitle is string && data.entityTitle.size() <= 200
               && data.rating is number && data.rating >= 1 && data.rating <= 10
               && data.comment is string && data.comment.size() <= 2000
               && data.createdAt is timestamp;
      }
      
      allow read: if true;
      
      allow create: if isSignedIn() 
                    && isValidReview(incoming())
                    && incoming().createdAt == request.time;
      
      allow update, delete: if false; // Immutable reviews
    }
    
    match /submissions/{submissionId} {
      function isValidSubmission(data) {
        return data.keys().hasAll(['userId', 'title', 'url', 'type', 'status', 'createdAt', 'updatedAt'])
               && data.size() == 7
               && data.userId is string && data.userId == request.auth.uid
               && data.title is string && data.title.size() > 0 && data.title.size() <= 200
               && data.url is string && data.url.size() <= 1000
               && data.type is string && data.type in ['idea', 'video', 'channel']
               && data.status is string && data.status in ['pending', 'approved', 'rejected']
               && data.createdAt is timestamp
               && data.updatedAt is timestamp;
      }
      
      allow get: if true;
      allow list: if resource.data.userId == request.auth.uid || resource.data.status == 'approved';
      
      allow create: if isSignedIn() 
                    && isValidSubmission(incoming())
                    && incoming().status == 'pending'
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
                    
      allow update: if isSignedIn() 
                    && request.auth.uid == existing().userId
                    && isValidSubmission(incoming())
                    && incoming().userId == existing().userId
                    && incoming().createdAt == existing().createdAt
                    && incoming().status == existing().status // User cannot bypass status
                    && incoming().updatedAt == request.time;
      allow delete: if false;
    }
    
    match /leaderboard/{entityId} {
      function isValidLeaderboard(data) {
        return data.keys().hasAll(['entityId', 'title', 'subscriberCount', 'positiveRatings', 'fairScore', 'baseAIscore', 'updatedAt'])
               && data.size() == 7
               && data.entityId is string && data.entityId.size() <= 128
               && data.title is string && data.title.size() <= 200
               && data.subscriberCount is number && data.subscriberCount >= 0
               && data.positiveRatings is number && data.positiveRatings >= 0
               && data.fairScore is number && data.fairScore >= 0
               && data.baseAIscore is number && data.baseAIscore >= 0
               && data.updatedAt is timestamp;
      }
      
      allow read: if true;
      
      allow create: if isSignedIn() 
                    && isValidId(entityId)
                    && isValidLeaderboard(incoming())
                    && incoming().entityId == entityId
                    && incoming().updatedAt == request.time;
                    
      allow update: if isSignedIn() 
                    && isValidLeaderboard(incoming())
                    && incoming().entityId == existing().entityId
                    && incoming().title == existing().title
                    && incoming().updatedAt == request.time;
                    
      allow delete: if false;
    }
  }
}
